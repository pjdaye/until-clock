<Window
    x:Class="UntilClock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24,16,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header row ─────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock
                Text="Until Clock"
                FontSize="15"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />

            <ToggleButton
                x:Name="AlwaysOnTopToggle"
                Content="📌"
                ToolTipService.ToolTip="Always on top"
                Click="AlwaysOnTopToggle_Click"
                HorizontalAlignment="Right"
                Padding="8,4"
                FontSize="14" />
        </Grid>

        <!-- ─── Countdown area ─────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Spacing="6" VerticalAlignment="Center">

            <!-- Target date/time label -->
            <TextBlock
                Text="{x:Bind ViewModel.TargetDisplay, Mode=OneWay}"
                FontSize="13"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Margin="0,0,0,8" />

            <!-- Digit groups: [DD :] HH : MM : SS -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="0">

                <!-- Days (only shown when ≥ 1 day remains) -->
                <StackPanel Visibility="{x:Bind ViewModel.DaysVisibility, Mode=OneWay}">
                    <TextBlock
                        Text="{x:Bind ViewModel.DaysDisplay, Mode=OneWay}"
                        FontSize="52"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        MinWidth="76"
                        FontFamily="Segoe UI Variable Display" />
                    <TextBlock
                        Text="DAYS"
                        FontSize="10"
                        TextAlignment="Center"
                        CharacterSpacing="150"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock
                    Text=":"
                    FontSize="52"
                    FontWeight="Bold"
                    Margin="4,0"
                    VerticalAlignment="Top"
                    Padding="0,0,0,18"
                    Visibility="{x:Bind ViewModel.DaysVisibility, Mode=OneWay}" />

                <!-- Hours -->
                <StackPanel>
                    <TextBlock
                        Text="{x:Bind ViewModel.HoursDisplay, Mode=OneWay}"
                        FontSize="52"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        MinWidth="76"
                        FontFamily="Segoe UI Variable Display" />
                    <TextBlock
                        Text="HRS"
                        FontSize="10"
                        TextAlignment="Center"
                        CharacterSpacing="150"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock
                    Text=":"
                    FontSize="52"
                    FontWeight="Bold"
                    Margin="4,0"
                    VerticalAlignment="Top"
                    Padding="0,0,0,18" />

                <!-- Minutes -->
                <StackPanel>
                    <TextBlock
                        Text="{x:Bind ViewModel.MinutesDisplay, Mode=OneWay}"
                        FontSize="52"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        MinWidth="76"
                        FontFamily="Segoe UI Variable Display" />
                    <TextBlock
                        Text="MIN"
                        FontSize="10"
                        TextAlignment="Center"
                        CharacterSpacing="150"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock
                    Text=":"
                    FontSize="52"
                    FontWeight="Bold"
                    Margin="4,0"
                    VerticalAlignment="Top"
                    Padding="0,0,0,18" />

                <!-- Seconds -->
                <StackPanel>
                    <TextBlock
                        Text="{x:Bind ViewModel.SecondsDisplay, Mode=OneWay}"
                        FontSize="52"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        MinWidth="76"
                        FontFamily="Segoe UI Variable Display" />
                    <TextBlock
                        Text="SEC"
                        FontSize="10"
                        TextAlignment="Center"
                        CharacterSpacing="150"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- "Time's up!" message shown when the countdown expires -->
            <TextBlock
                Text="🎉 Time's up!"
                FontSize="20"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Visibility="{x:Bind ViewModel.ExpiredVisibility, Mode=OneWay}" />

        </StackPanel>

        <!-- ─── Footer button ──────────────────────────────────────── -->
        <Button
            Grid.Row="2"
            Content="Set Target Time"
            Click="SetTargetButton_Click"
            HorizontalAlignment="Stretch"
            Margin="0,16,0,0" />

    </Grid>
</Window>
